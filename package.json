    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^2.2.0",
    "@types/nodemailer": "^8.0.1",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "bcrypt": "^6.0.0",
    "concurrently": "^9.2.3",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "lucide-react": "^1.23.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "papaparse": "^5.5.4",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.23.0",
    "xlsx": "^0.18.5"
