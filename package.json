    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "^10.1.0",
    "oxlint": "^1.72.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.3"
  }
