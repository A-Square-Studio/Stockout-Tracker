{
  "name": "stockout-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"api,web\" -c \"cyan,magenta\" \"tsx --env-file=.env server/index.ts\" \"vite\"",
